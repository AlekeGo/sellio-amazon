DEBUG=False
SECRET_KEY=your_secret_key
ALLOWED_HOSTS=api.wesellio.com,your-backend-host.com
CORS_ALLOWED_ORIGINS=https://wesellio.com,https://www.wesellio.com
CSRF_TRUSTED_ORIGINS=https://wesellio.com,https://www.wesellio.com
FRONTEND_URL=https://wesellio.com

DATABASE_URL=your_database_url

CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

FAL_KEY=your_fal_api_key
IMAGE_PROVIDER=fal
FAL_TEXT_TO_IMAGE_MODEL=fal-ai/flux/schnell
FAL_KONTEXT_MODEL=fal-ai/flux-pro/kontext

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your_resend_api_key
DEFAULT_FROM_EMAIL=Sellio <no-reply@wesellio.com>

PAYMENT_PROVIDER=polar
POLAR_ENV=sandbox
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=your_polar_token
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_LAUNCH_PRODUCT_ID=your_launch_product_id
POLAR_PRO_PRODUCT_ID=your_pro_product_id
POLAR_GROWTH_PRODUCT_ID=your_growth_product_id
POLAR_AGENCY_PRODUCT_ID=your_agency_product_id
POLAR_SUCCESS_URL=https://wesellio.com/billing/success
POLAR_CANCEL_URL=https://wesellio.com/billing/cancel
